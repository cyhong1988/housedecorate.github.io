// 讀取資料
function doGet() {
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  var data = sheet.getDataRange().getValues();
  var headers = data[0];
  var jsonData = [];
  
  for (var i = 1; i < data.length; i++) {
    var obj = {};
    for (var j = 0; j < headers.length; j++) {
      obj[headers[j]] = data[i][j];
    }
    jsonData.push(obj);
  }
  
  return ContentService.createTextOutput(JSON.stringify(jsonData))
    .setMimeType(ContentService.MimeType.JSON);
}

// 處理新增、修改、刪除、排序
function doPost(e) {
  var params = JSON.parse(e.postData.contents);
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  var data = sheet.getDataRange().getValues();
  var action = params.action;

  if (action === 'ADD') {
    // 新增時預設 purchased 為 false
    sheet.appendRow([params.id, params.category, params.name, params.url, params.price, false]);
  } 
  
  else if (action === 'UPDATE') {
    for (var i = 1; i < data.length; i++) {
      if (data[i][0] == params.id) { // 比對 ID
        var row = i + 1;
        // 更新對應欄位 (假設順序是 id, cat, name, url, price, purchased)
        sheet.getRange(row, 3).setValue(params.name);
        sheet.getRange(row, 4).setValue(params.url);
        sheet.getRange(row, 5).setValue(params.price);
        sheet.getRange(row, 6).setValue(params.purchased); // 這裡儲存勾選狀態
        break;
      }
    }
  } 
  
  else if (action === 'DELETE') {
    for (var i = 1; i < data.length; i++) {
      if (data[i][0] == params.id) {
        sheet.deleteRow(i + 1);
        break;
      }
    }
  }
  
  // 排序 (REORDER) 邏輯通常較複雜，若只需簡單記憶狀態，UPDATE 已足夠
  
  return ContentService.createTextOutput("Success");
}
